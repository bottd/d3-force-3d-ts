{
  "name": "d3-force-3d-ts",
  "version": "1.0.0",
  "description": "Force-directed graph layout in 1D, 2D or 3D using velocity Verlet integration.",
  "homepage": "https://github.com/bottd/d3-force-3d-ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/bottd/d3-force-3d-ts.git"
  },
  "keywords": [
    "d3",
    "d3-module",
    "layout",
    "network",
    "graph",
    "force",
    "verlet",
    "infovis",
    "3d"
  ],
  "license": "MIT",
  "author": {
    "name": "Vasco Asturiano",
    "url": "https://github.com/vasturiano"
  },
  "contributors": [
    {
      "name": "Drake Bott",
      "url": "https://github.com/bottd"
    }
  ],
  "type": "module",
  "files": [
    "src/**/*.js",
    "dist/**/*.js"
  ],
  "module": "src/index.js",
  "main": "src/index.js",
  "exports": {
    "import": "./dist/d3-force-3d.js",
    "default": "./src/index.js"
  },
  "sideEffects": false,
  "peerDependencies": {
    "d3-binarytree": "1",
    "d3-dispatch": "1 - 3",
    "d3-octree": "1",
    "d3-quadtree": "1 - 3",
    "d3-timer": "1 - 3"
  },
  "devDependencies": {
    "eslint": "10.1.0",
    "typescript": "6.0.2",
    "vite": "8.0.3",
    "vitest": "4.1.2"
  },
  "scripts": {
    "build": "vite build",
    "test": "vitest run && eslint src test",
    "prepare": "rm -rf dist && pnpm test && pnpm build"
  },
  "engines": {
    "node": ">=18"
  }
}
