{
  "name": "d3-force-3d-ts",
  "version": "1.0.0",
  "description": "Force-directed graph layout in 1D, 2D or 3D using velocity Verlet integration.",
  "homepage": "https://github.com/bottd/d3-force-3d-ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/bottd/d3-force-3d-ts.git"
  },
  "keywords": [
    "d3",
    "d3-module",
    "layout",
    "network",
    "graph",
    "force",
    "verlet",
    "infovis",
    "3d"
  ],
  "license": "MIT",
  "author": {
    "name": "Vasco Asturiano",
    "url": "https://github.com/vasturiano"
  },
  "contributors": [
    {
      "name": "Drake Bott",
      "url": "https://github.com/bottd"
    }
  ],
  "type": "module",
  "files": [
    "dist"
  ],
  "module": "./dist/d3-force-3d-ts.js",
  "main": "./dist/d3-force-3d-ts.js",
  "types": "./dist/index.d.ts",
