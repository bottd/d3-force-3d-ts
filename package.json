    "@semantic-release/npm": "13.1.5",
    "@types/d3-dispatch": "3.0.7",
    "@types/d3-quadtree": "3.0.6",
    "@types/d3-timer": "3.0.2",
    "eslint": "10.1.0",
    "semantic-release": "25.0.3",
    "typescript": "6.0.2",
    "vite": "8.0.3",
    "vite-plugin-dts": "4.5.4",
    "vitest": "4.1.2"
  },
  "scripts": {
    "build": "vite build",
    "test": "vitest run"
  },
  "packageManager": "pnpm@10.33.0",
